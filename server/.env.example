# Google OAuth (Google Cloud Console -> Credentials -> OAuth client, Typ "Web")
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# Erlaubte Logins (comma-separated). Eintraege: exakte Email ODER Domain-Wildcard.
# "@taikonauten.com" laesst alle @taikonauten.com-Adressen rein.
ALLOWED_EMAILS=@taikonauten.com

# Admins: duerfen Tools anlegen/bearbeiten/loeschen + pro Nutzer freigeben.
# Alle anderen sehen nur freigegebene Tools (anordnen + aus-/einblenden).
ADMIN_EMAILS=mf@taikonauten.com

# Sessions ueberleben Neustart nur mit gesetztem Secret (sonst random).
SESSION_SECRET=aendere-mich-zu-einem-langen-random-string

# Prod: oeffentliche URL (Cloudflare Tunnel). Redirect-URI in der Google Console
# muss ${APP_URL}/api/auth/login/callback sein. Dev: weglassen.
# APP_URL=https://taikohub.example.com

PORT=3006
# NODE_ENV=production
