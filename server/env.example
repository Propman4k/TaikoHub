# TaikoHub Server — Konfigurations-Vorlage.
# Als server/.env kopieren und Werte eintragen. (Heisst env.example ohne
# fuehrenden Punkt, weil .env*-Pfade im Agent-Setup schreibgeschuetzt sind.)

# Google OAuth-Client "TaikoHub - Web" (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Login-Allowlist: exakte Emails ODER Domain-Wildcards, kommagetrennt.
# "@taikonauten.com" = ganze Domain
ALLOWED_EMAILS=@taikonauten.com

# Admins (Tool-Katalog + Mitarbeiterverwaltung)
ADMIN_EMAILS=mf@taikonauten.com

# Cookie-Signatur — Pflicht in Produktion (Server startet sonst nicht)
SESSION_SECRET=

# Origin, auf dem der Browser die App sieht (bestimmt OAuth-Redirect-URI).
# Dev: http://localhost:3005 (Vite-Client!). Prod: Cloudflare-Tunnel-URL.
# Google Console muss ${APP_URL}/api/auth/login/callback exakt enthalten.
APP_URL=http://localhost:3005

# 3006 dev / 3007 prod (3002-3006 sind auf der NAS belegt)
PORT=3006

# In Produktion setzen:
# NODE_ENV=production
